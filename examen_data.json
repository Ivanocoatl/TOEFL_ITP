<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TOEFL ITP Simulator - Multi-Test Edition</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&display=swap');
        body { font-family: 'Inter', sans-serif; background-color: #f1f5f9; }
        
        .toefl-radio {
            appearance: none;
            width: 20px;
            height: 20px;
            border: 2px solid #94a3b8;
            border-radius: 50%;
            cursor: pointer;
            transition: all 0.2s;
        }
        .toefl-radio:checked {
            background-color: #1e293b;
            border-color: #1e293b;
            box-shadow: inset 0 0 0 4px #fff;
        }
        
        .option-correct { background-color: #f0fdf4; border-color: #22c55e; }
        .option-wrong { background-color: #fef2f2; border-color: #ef4444; }
        
        .hidden-section { display: none; }
        
        /* Animaciones para la transición de preguntas */
        .fade-step { animation: fadeIn 0.4s ease-out; }
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }
    </style>
</head>
<body class="h-screen flex flex-col overflow-hidden text-slate-800">

    <!-- HEADER SUPERIOR -->
    <header class="bg-slate-900 text-white p-4 flex justify-between items-center shadow-lg shrink-0">
        <div class="flex items-center gap-3">
            <div class="bg-blue-600 p-2 rounded-lg">
                <i class="fas fa-certificate text-xl"></i>
            </div>
            <div>
                <h1 class="text-lg font-extrabold tracking-tight">TOEFL ITP® SIMULATOR</h1>
                <p id="current-test-label" class="text-[10px] text-blue-300 font-bold uppercase">Selecciona Examen</p>
            </div>
        </div>
        
        <div class="flex items-center gap-4">
            <div id="mode-indicator" class="bg-slate-800 px-3 py-1 rounded-full text-[10px] font-bold border border-slate-700">MODO REAL LIFE</div>
            <div class="bg-slate-700 px-4 py-2 rounded-lg font-mono text-xl text-blue-400 border border-slate-600">
                <span id="timer">00:00</span>
            </div>
            <button onclick="window.location.reload()" class="hover:text-red-400 transition-colors">
                <i class="fas fa-power-off"></i>
            </button>
        </div>
    </header>

    <!-- PANTALLA DE CARGA -->
    <div id="loading-screen" class="absolute inset-0 bg-white z-50 flex flex-col items-center justify-center">
        <div class="animate-spin rounded-full h-12 w-12 border-b-4 border-blue-600 mb-4"></div>
        <h2 class="text-xl font-bold">Iniciando Entorno...</h2>
    </div>

    <div class="flex flex-1 overflow-hidden">
        
        <!-- SIDEBAR DE NAVEGACIÓN -->
        <aside class="w-64 bg-white border-r shadow-inner flex flex-col">
            <div class="p-5 border-b bg-slate-50">
                <h2 class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Navegación</h2>
            </div>
            <nav class="flex-1">
                <button onclick="cambiarVista('setup')" class="w-full text-left p-4 border-b hover:bg-slate-50 flex items-center gap-3">
                    <i class="fas fa-cog text-slate-400"></i> Configuración Inicial
                </button>
                <div id="test-nav" class="opacity-40 pointer-events-none">
                    <button id="nav-listening" onclick="cambiarVista('listening')" class="w-full text-left p-4 border-b hover:bg-slate-50 flex items-center gap-3">
                        <i class="fas fa-headphones text-blue-500"></i> Listening Section
                    </button>
                    <button id="nav-structure" onclick="cambiarVista('structure')" class="w-full text-left p-4 border-b hover:bg-slate-50 flex items-center gap-3">
                        <i class="fas fa-pen-nib text-green-500"></i> Structure Section
                    </button>
                    <button id="nav-reading" onclick="cambiarVista('reading')" class="w-full text-left p-4 border-b hover:bg-slate-50 flex items-center gap-3">
                        <i class="fas fa-book-open text-purple-500"></i> Reading Section
                    </button>
                </div>
            </nav>
            <div id="pagination-status" class="p-4 bg-slate-50 border-t text-[10px] font-bold text-slate-500 uppercase hidden">
                Bloque <span id="current-step">1</span> de <span id="total-steps">1</span>
            </div>
        </aside>

        <!-- ÁREA PRINCIPAL -->
        <main class="flex-1 overflow-y-auto p-8 relative">
            <div class="max-w-4xl mx-auto min-h-full">

                <!-- VISTA: SETUP -->
                <div id="view-setup" class="space-y-8 animate-in fade-in duration-500">
                    <div class="text-center py-10">
                        <h2 class="text-4xl font-black mb-4">Bienvenido, Doc</h2>
                        <p class="text-slate-500">Configura tu sesión de entrenamiento de hoy.</p>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="bg-white p-8 rounded-3xl shadow-sm border-2 border-slate-100 hover:border-blue-500 transition-all cursor-pointer group" onclick="seleccionarTest('testA')">
                            <div class="w-16 h-16 bg-blue-100 text-blue-600 rounded-2xl flex items-center justify-center text-3xl mb-6 group-hover:scale-110 transition-transform">
                                <i class="fas fa-font"></i>
                            </div>
                            <h3 class="text-2xl font-bold mb-2">Practice Test A</h3>
                            <p class="text-sm text-slate-500 mb-6 leading-relaxed">Corresponde al Audio A. Basado en la página 19 del PDF oficial.</p>
                            <span class="text-xs font-bold text-blue-600 uppercase">Seleccionar Test A →</span>
                        </div>

                        <div class="bg-white p-8 rounded-3xl shadow-sm border-2 border-slate-100 hover:border-blue-500 transition-all cursor-pointer group" onclick="seleccionarTest('testB')">
                            <div class="w-16 h-16 bg-slate-100 text-slate-600 rounded-2xl flex items-center justify-center text-3xl mb-6 group-hover:scale-110 transition-transform">
                                <i class="fas fa-bold"></i>
                            </div>
                            <h3 class="text-2xl font-bold mb-2">Practice Test B</h3>
                            <p class="text-sm text-slate-500 mb-6 leading-relaxed">Corresponde al Audio B. Basado en la página 59 del PDF oficial.</p>
                            <span class="text-xs font-bold text-slate-600 uppercase">Seleccionar Test B →</span>
                        </div>
                    </div>

                    <div class="bg-orange-50 border border-orange-200 p-6 rounded-2xl flex items-center justify-between gap-6">
                        <div class="flex items-center gap-4">
                            <div class="text-orange-500 text-3xl"><i class="fas fa-graduation-cap"></i></div>
                            <div>
                                <h4 class="font-bold text-orange-800">Modo Aprendizaje</h4>
                                <p class="text-xs text-orange-700">Recibe correcciones y explicaciones técnicas al instante.</p>
                            </div>
                        </div>
                        <button id="btn-toggle-learning" onclick="toggleLearning()" class="bg-orange-200 text-orange-800 px-6 py-2 rounded-full font-bold text-sm hover:bg-orange-300 transition-all">
                            DESACTIVADO
                        </button>
                    </div>
                </div>

                <!-- VISTA: LISTENING -->
                <div id="view-listening" class="hidden-section space-y-8 pb-20">
                    <div class="bg-slate-900 text-white p-8 rounded-3xl shadow-2xl relative overflow-hidden">
                        <div class="relative z-10 flex flex-col md:flex-row items-center justify-between gap-8">
                            <div class="flex-1">
                                <h2 id="listening-title" class="text-2xl font-black mb-2 tracking-tight">SECTION 1: LISTENING</h2>
                                <div class="flex items-center gap-4 text-xs font-bold text-blue-400">
                                    <span><i class="fas fa-volume-up"></i> AUDIO CARGADO</span>
                                    <span><i class="fas fa-clock"></i> 35 MINUTOS</span>
                                </div>
                            </div>
                            <div class="w-full md:w-auto flex flex-col items-end gap-3">
                                <audio id="main-audio" controls class="w-full h-10"></audio>
                                <label class="text-[9px] text-slate-500 uppercase tracking-widest cursor-pointer hover:text-blue-400">
                                    Cargar Audio Local <input type="file" id="local-audio" accept="audio/*" class="hidden">
                                </label>
                            </div>
                        </div>
                    </div>

                    <div id="container-listening" class="grid grid-cols-1 gap-6 fade-step"></div>

                    <!-- BOTONES DE NAVEGACIÓN DE PREGUNTAS -->
                    <div id="pagination-controls" class="flex justify-between items-center mt-10">
                        <button id="prev-step" onclick="cambiarBloque(-1)" class="bg-slate-200 text-slate-600 px-6 py-2 rounded-xl font-bold text-sm hover:bg-slate-300 disabled:opacity-30">
                            <i class="fas fa-arrow-left mr-2"></i> Anterior
                        </button>
                        <button id="next-step" onclick="cambiarBloque(1)" class="bg-slate-900 text-white px-6 py-2 rounded-xl font-bold text-sm hover:bg-slate-800 disabled:opacity-30">
                            Siguiente <i class="fas fa-arrow-right ml-2"></i>
                        </button>
                    </div>
                </div>

                <!-- VISTAS DE RELLENO -->
                <div id="view-structure" class="hidden-section text-center py-20">
                    <i class="fas fa-pen-nib text-5xl text-slate-200 mb-6"></i>
                    <h2 class="text-2xl font-bold">Sección en Desarrollo</h2>
                    <p class="text-slate-400">Esta sección se activará al cargar el JSON completo.</p>
                </div>
                <div id="view-reading" class="hidden-section text-center py-20">
                    <i class="fas fa-book-open text-5xl text-slate-200 mb-6"></i>
                    <h2 class="text-2xl font-bold">Sección en Desarrollo</h2>
                    <p class="text-slate-400">Los pasajes de lectura se leen directamente del PDF.</p>
                </div>

            </div>
        </main>
    </div>

    <script>
        let db = null;
        let currentTest = null;
        let learningMode = false;
        let timerInterval;
        
        // Paginación de preguntas
        let currentStep = 0;
        const questionsPerStep = 2; // Mostraremos de 2 en 2 como sugeriste

        document.addEventListener('DOMContentLoaded', () => {
            fetch('examen_data.json', { cache: "no-store" })
                .then(r => r.json())
                .then(data => {
                    db = data;
                    document.getElementById('loading-screen').style.display = 'none';
                })
                .catch(e => {
                    alert("Error: Asegúrate de tener el archivo examen_data.json en la misma carpeta.");
                    console.error(e);
                });
        });

        function toggleLearning() {
            learningMode = !learningMode;
            const btn = document.getElementById('btn-toggle-learning');
            const badge = document.getElementById('mode-indicator');
            btn.innerText = learningMode ? "ACTIVADO" : "DESACTIVADO";
            btn.className = learningMode ? "bg-orange-500 text-white px-6 py-2 rounded-full font-bold text-sm shadow-lg" : "bg-orange-200 text-orange-800 px-6 py-2 rounded-full font-bold text-sm hover:bg-orange-300 transition-all";
            badge.innerText = learningMode ? "MODO APRENDIZAJE" : "MODO REAL LIFE";
            badge.className = learningMode ? "bg-orange-100 text-orange-700 px-3 py-1 rounded-full text-[10px] font-bold border border-orange-200" : "bg-slate-800 px-3 py-1 rounded-full text-[10px] font-bold border border-slate-700";
        }

        function seleccionarTest(testId) {
            currentTest = testId;
            currentStep = 0;
            document.getElementById('current-test-label').innerText = testId === 'testA' ? "Practice Test A" : "Practice Test B";
            document.getElementById('test-nav').classList.remove('opacity-40', 'pointer-events-none');
            
            const audio = document.getElementById('main-audio');
            const audioId = testId === 'testA' ? '1YfZ1zZCL-Zlie5f6w03VRpPh3DzCHMRU' : '1uDKuutxP9uLTYm4rBtz1NMeOCRC2hMlc';
            audio.src = `https://drive.google.com/uc?export=download&id=${audioId}`;
            
            renderizarBloque();
            cambiarVista('listening');
            iniciarCronometro(35);
        }

        function cambiarVista(id) {
            document.querySelectorAll('main > div > div').forEach(el => el.classList.add('hidden-section'));
            document.getElementById('view-' + id).classList.remove('hidden-section');
            window.scrollTo(0,0);
        }

        function cambiarBloque(delta) {
            const data = db[currentTest].listening;
            const totalSteps = Math.ceil(data.length / questionsPerStep);
            
            currentStep += delta;
            if (currentStep < 0) currentStep = 0;
            if (currentStep >= totalSteps) currentStep = totalSteps - 1;
            
            renderizarBloque();
        }

        function renderizarBloque() {
            const container = document.getElementById('container-listening');
            container.innerHTML = '';
            const data = db[currentTest].listening;
            const alphabet = ['A', 'B', 'C', 'D'];
            
            const start = currentStep * questionsPerStep;
            const end = start + questionsPerStep;
            const slice = data.slice(start, end);
            
            // Actualizar status de paginación
            document.getElementById('pagination-status').classList.remove('hidden');
            document.getElementById('current-step').innerText = currentStep + 1;
            document.getElementById('total-steps').innerText = Math.ceil(data.length / questionsPerStep);
            
            // Control de botones
            document.getElementById('prev-step').disabled = currentStep === 0;
            document.getElementById('next-step').disabled = currentStep === (Math.ceil(data.length / questionsPerStep) - 1);

            slice.forEach(q => {
                const card = document.createElement('div');
                card.className = "bg-white p-6 rounded-3xl border border-slate-100 shadow-sm space-y-4 mb-4";
                card.innerHTML = `
                    <div class="flex items-center justify-between border-b pb-4">
                        <div class="flex items-center gap-3">
                            <span class="w-8 h-8 bg-slate-900 text-white rounded-lg flex items-center justify-center font-black text-xs">${q.id}</span>
                            <h4 class="font-bold text-slate-700 text-sm">${q.pregunta}</h4>
                        </div>
                        <span class="text-[10px] font-mono font-bold text-slate-400 bg-slate-50 px-2 py-1 rounded border tracking-widest"><i class="far fa-clock mr-1"></i>${q.timestamp}</span>
                    </div>
                    <div class="grid grid-cols-1 gap-2" id="q-${q.id}-options">
                        ${q.opciones.map((op, idx) => `
                            <label class="flex items-center p-3 rounded-xl border-2 border-slate-50 hover:bg-slate-50 transition-all cursor-pointer group" id="label-${q.id}-${alphabet[idx]}">
                                <input type="radio" name="q-${q.id}" value="${alphabet[idx]}" class="toefl-radio" onchange="verificar(${q.id}, '${alphabet[idx]}')">
                                <span class="ml-3 text-sm text-slate-600 group-hover:text-slate-900">${op}</span>
                            </label>
                        `).join('')}
                    </div>
                    <div id="feedback-${q.id}" class="mt-4 p-4 rounded-2xl hidden"></div>
                `;
                container.appendChild(card);
            });
            
            // Hacer scroll al inicio suavemente
            document.querySelector('main').scrollTo({ top: 0, behavior: 'smooth' });
        }

        function verificar(qId, selected) {
            if (!learningMode) return;
            
            const qData = db[currentTest].listening.find(x => x.id === qId);
            const correct = qData.correcta;
            const feedback = document.getElementById(`feedback-${qId}`);
            
            document.querySelectorAll(`input[name="q-${qId}"]`).forEach(input => input.disabled = true);
            
            const labelSelected = document.getElementById(`label-${qId}-${selected}`);
            const labelCorrect = document.getElementById(`label-${qId}-${correct}`);

            feedback.classList.remove('hidden');
            if (selected === correct) {
                labelSelected.classList.add('option-correct');
                feedback.className = "mt-4 p-4 rounded-2xl bg-green-50 text-green-800 text-xs border border-green-200";
                feedback.innerHTML = `<p class="font-bold mb-1"><i class="fas fa-check-circle mr-2"></i>¡CORRECTO!</p><p>${qData.explicacion}</p>`;
            } else {
                labelSelected.classList.add('option-wrong');
                if (labelCorrect) labelCorrect.classList.add('option-correct');
                feedback.className = "mt-4 p-4 rounded-2xl bg-red-50 text-red-800 text-xs border border-red-200";
                feedback.innerHTML = `<p class="font-bold mb-1"><i class="fas fa-times-circle mr-2"></i>INCORRECTO</p><p class="mb-2">La respuesta correcta es la (${correct}).</p><p class="opacity-80">${qData.explicacion}</p>`;
            }
        }

        function iniciarCronometro(minutos) {
            clearInterval(timerInterval);
            let total = minutos * 60;
            timerInterval = setInterval(() => {
                let m = Math.floor(total / 60);
                let s = total % 60;
                document.getElementById('timer').innerText = `${m < 10 ? '0'+m : m}:${s < 10 ? '0'+s : s}`;
                if (total <= 0) clearInterval(timerInterval);
                total--;
            }, 1000);
        }

        document.getElementById('local-audio').addEventListener('change', (e) => {
            const url = URL.createObjectURL(e.target.files[0]);
            document.getElementById('main-audio').src = url;
        });
    </script>
</body>
</html>
